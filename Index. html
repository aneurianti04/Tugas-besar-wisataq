<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Visit Banyuwangi</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- NAVBAR -->
<header>
    <h1>Visit Banyuwangi</h1>
    <nav>
        <a href="#destinasi">Destinasi</a>
        <a href="#aktivitas">Aktivitas</a>
        <a href="#budaya">Budaya</a>
        <a href="#kuliner">Kuliner</a>
        <a href="#plan">Plan Trip</a>
        <a href="#booking">Booking</a>
    </nav>
</header>

<!-- HERO SECTION -->
<section class="hero">
    <video autoplay muted loop>
        <source src="video.mp4" type="video/mp4">
    </video>
    <div class="hero-text">
        <h2>Explore The Sunrise of Java</h2>

        <!-- SMART SEARCH -->
        <div class="search-box">
            <select>
                <option>Pantai</option>
                <option>Kuliner</option>
                <option>Budaya</option>
                <option>Gunung</option>
            </select>
            <input type="date">
            <button>Cari</button>
        </div>
    </div>
</section>

<!-- DESTINASI -->
<section id="destinasi">
    <h2>Highlight Destinasi</h2>
    <div class="card-container">
        <div class="card">
            <img src="img1.jpg">
            <h3>Kawah Ijen</h3>
        </div>
        <div class="card">
            <img src="img2.jpg">
            <h3>Pantai Pulau Merah</h3>
        </div>
        <div class="card">
            <img src="img3.jpg">
            <h3>Taman Nasional Baluran</h3>
        </div>
    </div>
</section>

<!-- EVENTS -->
<section>
    <h2>Upcoming Events</h2>
    <ul>
        <li>Banyuwangi Festival - Juli</li>
        <li>Gandrung Sewu - Oktober</li>
        <li>Jazz Pantai - Desember</li>
    </ul>
</section>

<!-- PETA -->
<section>
    <h2>Peta Wilayah</h2>
    <iframe src="https://www.google.com/maps/embed?pb=!1m18..."
    width="100%" height="300" style="border:0;"></iframe>
</section>

<!-- AKTIVITAS -->
<section id="aktivitas">
    <h2>Top 10 Experiences</h2>
    <ol>
        <li>Melihat Blue Fire Kawah Ijen</li>
        <li>Snorkeling Pulau Tabuhan</li>
        <li>Safari Baluran</li>
        <li>Belajar Tari Gandrung</li>
    </ol>
</section>

<!-- BUDAYA -->
<section id="budaya">
    <h2>Culture & Heritage</h2>
    <p>Banyuwangi memiliki budaya Osing yang unik dan kaya tradisi.</p>
    <h3>Etika Lokal</h3>
    <ul>
        <li>Berpakaian sopan di tempat ibadah</li>
        <li>Gunakan bahasa santun</li>
    </ul>
</section>

<!-- KULINER -->
<section id="kuliner">
    <h2>Must Eat Dishes</h2>
    <ul>
        <li>Sego Tempong</li>
        <li>Rujak Soto</li>
        <li>Pecel Pitik</li>
    </ul>
</section>

<!-- PLAN YOUR TRIP -->
<section id="plan">
    <h2>Plan Your Trip</h2>
    <p>Transportasi: Bandara Banyuwangi & Kereta Api</p>
    <p>Mata Uang: Rupiah (IDR)</p>
</section>

<!-- ITINERARY -->
<section>
    <h2>Sample Itinerary</h2>
    <h3>7 Hari</h3>
    <p>Hari 1-2: Kawah Ijen</p>
    <p>Hari 3-4: Pantai</p>
</section>

<!-- AKOMODASI -->
<section>
    <h2>Where to Stay</h2>
    <ul>
        <li>Resort Pantai Pulau Merah</li>
        <li>Homestay Osing</li>
    </ul>
</section>

<!-- RESPONSIBLE TRAVEL -->
<section>
    <h2>Responsible Travel</h2>
    <p>Dukung UMKM lokal dan hindari plastik sekali pakai.</p>
</section>

<!-- HELP CENTER -->
<section>
    <h2>Emergency Numbers</h2>
    <p>Polisi: 110</p>
    <p>Ambulans: 118</p>

    <h3>Chatbot AI</h3>
    <input type="text" id="chatInput" placeholder="Tanya sesuatu...">
    <button onclick="chatbot()">Kirim</button>
    <p id="chatResponse"></p>
</section>

<!-- FORM BOOKING -->
<section id="booking">
    <h2>Form Pemesanan</h2>
    <form id="bookingForm">
        <input type="text" placeholder="Nama Lengkap" required>
        <input type="email" placeholder="Email" required>
        <input type="number" placeholder="Jumlah Orang" required>
        <input type="date" required>
        <select required>
            <option value="">Pilih Destinasi</option>
            <option>Kawah Ijen</option>
            <option>Pantai Pulau Merah</option>
        </select>
        <button type="submit">Pesan Sekarang</button>
    </form>
    <p id="notif"></p>
</section>
<script src="script.js"></script>
</body>
</html>
