// Chatbot sederhana
function chatbot() {
    let input = document.getElementById("chatInput").value;
    let response = document.getElementById("chatResponse");

    if(input.toLowerCase().includes("pantai")) {
        response.innerText = "Pantai terbaik adalah Pulau Merah!";
    } else {
        response.innerText = "Terima kasih sudah bertanya 😊";
    }
}

